{
  "name": "vaultx",
  "productName": "VaultX",
  "version": "1.1.0",
  "description": "VaultX — Password Manager locale, sicuro, crittografia AES-256-GCM + Argon2id",
  "main": "main/main.js",
  "author": {
    "name": "VaultX",
    "email": "support@vaultx.local"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Simokkk/vaultx.git"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --dir",
    "release": "electron-builder --win --x64 --publish always",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "argon2": "^0.31.2",
    "better-sqlite3": "^11.3.0",
    "electron-updater": "^6.3.9"
  },
  "optionalDependencies": {
    "robotjs": "^0.6.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "local.vaultx.app",
    "productName": "VaultX",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "VaultX-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Simokkk",
        "repo": "vaultx",
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VaultX"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/argon2/**/*"
    ]
  }
}
